# Standard .gitignore für Frontend/Node-Projekte

# CI/CD
.github/
*.md
docs/

# But include the main README
!README.md

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml
package-lock.json
package.json

# Build outputs
/dist/
/build/
/out/

# Firebase config (contains sensitive credentials - never commit!)
config/firebase.config.js

# Env files
.env
.env.*.local

# Editor/IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# macOS
.DS_Store
.AppleDouble
._*

# Logs
logs/
npm-debug.log*

# Temporary directories
/tmp/
/temp/

# Cache
/.cache/
/.parcel-cache/
/.vite/
/.next/
/.nuxt/

# Test coverage
/coverage/

# Firebase
.firebase/

# OS files
Thumbs.db

# Misc
/dist-exports/


